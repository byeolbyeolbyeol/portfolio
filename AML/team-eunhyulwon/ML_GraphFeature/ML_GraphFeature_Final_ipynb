   on=\"From Account\", how=\"left\"\n",").join(\n","    all_nodes.lazy().rename({\"account\": \"To Account\", \"node_id\": \"dst_id\"}),\n","    on=\"To Account\", how=\"left\"\n",").with_columns([\n","    pl.col(\"src_id\").cast(pl.Int32),\n","    pl.col(\"dst_id\").cast(pl.Int32)\n","])\n","\n","# 3. edge_index 생성\n","# 이 단계는 아까와 동일하게 진행하시면 됩니다.\n","print(\"Collecting edge IDs...\")\n","# temp_edges = q_feat.select([\"src_id\", \"dst_id\"]).collect(engine=\"streaming\")\n","# (★ 누수 방지: Train 엣지만 추출)\n","temp_edges = q_feat.filter(pl.col(\"split\") == \"train\").select([\"src_id\", \"dst_id\"]).collect(engine=\"streaming\")\n","\n","\n","edge_index = torch.tensor(\n","    np.stack([\n","        temp_edges[\"src_id\"].to_numpy().astype(np.int32),\n","        temp_edges[\"dst_id\"].to_numpy().astype(np.int32)\n","    ]),\n","    dtype=torch.long\n",")\n","\n","del temp_edges\n","gc.collect()\n","\n","print(f\"edge_index created with {edge_index.shape[1]} edges.\")"]},{"cell_type":"markdown","metadata":{"id":"X0Zd74BkeLHd"},"source":["- 1차 피처: Degree, PageRank, HITS, Degree Ratio\n","- 이 단계는 가장 기본적이며 계산 속도가 빠릅니다."]},{"cell_type":"code","execution_count":null,"metadata":{"executionInfo":{"elapsed":6888,"status":"ok","timestamp":1773266067674,"user":{"displayName":"DS6기_01","userId":"15970101082274129131"},"user_tz":-540},"id":"4ys7BxmhURbT","colab":{"base_uri":"https://localhost:8080/"},"outputId":"5aa0e8da-3a78-4941-bb34-79e4a6c1c1ae"},"outputs":[{"output_type":"stream","name":"stdout","text":["Extracting 1st Tier Features...\n","PageRank iteration completed...\n","PageRank iteration completed...\n","PageRank iteration completed...\n","PageRank iteration completed...\n","PageRank iteration completed...\n","PageRank iteration completed...\n","PageRank iteration completed...\n","PageRank iteration completed...\n","PageRank iteration completed...\n","PageRank iteration completed...\n"]},{"output_type":"execute_result","data":{"text/plain":["136"]},"metadata":{},"execution_count":57}],"source":["import torch\n","from torch_geometric.utils import degree\n","import gc\n","\n","# --- (사전 준비) ---\n","# edge_index와 num_nodes는 이전 단계에서 생성되었다고 가정합니다.\n","device = 'cuda' if torch.cuda.is_available() else 'cpu'\n","# device = 'cpu' # 코랩 무료에서 3,200만 행은 CPU 메모리가 더 여유로울 수 있습니다.\n","\n","# --- 1차 생성: Degree & PageRank (Manual) ---\n","print(\"Extracting 1st Tier Features...\")\n","\n","# 1. Degree 계산\n","out_deg_vec = degree(edge_index[0], num_nodes=num_nodes).to(device)\n","in_deg_vec = degree(edge_index[1], num_nodes=num_nodes).to(device)\n","deg_ratio = (in_deg_vec + 1) / (out_deg_vec + 1)\n","\n","# 2. PageRank 수동 계산 (Power Iteration)\n","# PyG 내장함수보다 메모리 제어가 훨씬 쉽고 빠릅니다.\n","# def compute_pagerank(edge_index, num_nodes, alpha=0.85, iters=10):\n","#     pr = torch.ones((num_nodes,), device=device) / num_nodes\n","#     src, dst = edge_index[0], edge_index[1]\n","#     out_degree = degree(src, num_nodes=num_nodes)\n","\n","#     # 연결되지 않은 노드(dangling nodes) 처리용\n","#     out_degree[out_degree == 0] = 1.0\n","\n","#     for _ in range(iters):\n","#         # 메시지 전파: 각 노드의 PR을 out_degree로 나눠서 dst에 전달\n","#         msg = pr[src] / out_degree[src]\n","#         new_pr = torch.zeros_like(pr)\n","#         # scatter_add를 사용해 효율적으로 합산\n","#         new_pr.scatter_add_(0, dst, msg)\n","#         pr = (1 - alpha) / num_nodes + alpha * new_pr\n","#         print(f\"Iteration completed...\")\n","#     return pr.numpy().astype(np.float32)\n","\n","# pr_scores = compute_pagerank(edge_index, num_nodes)\n","\n","def compute_pagerank(edge_index, num_nodes, alpha=0.85, iters=10):\n","    # 1. edge_index가 현재 위치한 디바이스(GPU or CPU)를 확인\n","    dev = edge_index.device\n","\n","    # 2. 모든 텐서를 같은 디바이스(dev)에 생성\n","    pr = torch.ones((num_nodes,), device=dev) / num_nodes\n","    src, dst = edge_index[0], edge_index[1]\n","\n","    # 3. degree 결과물도 확실하게 같은 디바이스로 보냄\n","    out_degree = degree(src, num_nodes=num_nodes).to(dev)\n","\n","    # 연결되지 않은 노드(dangling nodes) 처리용\n","    out_degree[out_degree == 0] = 1.0\n","\n","    for _ in range(iters):\n","        # 메시지 전파: 각 노드의 PR을 out_degree로 나눠서 dst에 전달\n","        msg = pr[src] / out_degree[src]\n","        new_pr = torch.zeros_like(pr)\n","        # scatter_add를 사용해 효율적으로 합산\n","        new_pr.scatter_add_(0, dst, msg)\n","        pr = (1 - alpha) / num_nodes + alpha * new_pr\n","        print(f\"PageRank iteration completed...\")\n","\n","    # 4. GPU 연산이 끝났으므로 Polars에 넣기 위해 CPU로 내린 후 Numpy 변환\n","    return pr.cpu().numpy().astype(np.float32)\n","\n","# 함수 교체 후 아래 코드 실행\n","pr_scores = compute_pagerank(edge_index, num_nodes)\n","\n","# 결과 저장용 DataFrame 생성\n","node_feats = pl.DataFrame({\n","    \"node_id\": np.arange(num_nodes, dtype=np.int32),\n","    \"g_in_degree\": in_deg_vec.cpu().numpy().astype(np.float32),\n","    \"g_out_degree\": out_deg_vec.cpu().numpy().astype(np.float32),\n","    \"g_degree_ratio\": deg_ratio.cpu().numpy().astype(np.float32),\n","    \"g_pagerank\": pr_scores.astype(pl.Float32)\n","})\n","\n","# 메모리 정리\n","del in_deg_vec, out_deg_vec, deg_ratio, pr_scores\n","gc.collect()"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"Ge_xMxV-gsZf"},"outputs":[],"source":["# def compute_hits(edge_index, num_nodes, iters=5):\n","#     h = torch.ones((num_nodes,), device=device)\n","#     a = torch.ones((num_nodes,), device=device)\n","#     src, dst = edge_index[0], edge_index[1]\n","\n","#     for _ in range(iters):\n","#         # Authority: 자신에게 들어오는 Hub들의 합\n","#         a.fill_(0)\n","#         a.scatter_add_(0, dst, h[src])\n","#         a /= (a.max() + 1e-9)\n","\n","#         # Hub: 자신이 가리키는 Authority들의 합\n","#         h.fill_(0)\n","#         h.scatter_add_(0, src, a[dst])\n","#         h /= (h.max() + 1e-9)\n","#         print(\"HITS iteration completed...\")\n","#     return h, a\n","\n","# hits_h, hits_a = compute_hits(edge_index, num_nodes)\n","\n","# # 기존 node_feats에 병합\n","# node_feats = node_feats.with_columns([\n","#     pl.Series(\"g_hits_hub\", hits_h.cpu().numpy()).cast(pl.Float32),\n","#     pl.Series(\"g_hits_auth\", hits_a.cpu().numpy()).cast(pl.Float32)\n","# ])\n","\n","# del hits_h, hits_a\n","# gc.collect()"]},{"cell_type":"code","source":["# ==========================================\n","# ★ 수정된 HITS 함수 (디바이스 자동 일치 및 CPU 반환)\n","# ==========================================\n","def compute_hits(edge_index, num_nodes, iters=5):\n","    # 1. edge_index가 현재 위치한 디바이스(GPU or CPU)를 확인\n","    dev = edge_index.device\n","\n","    # 2. 연산에 쓰일 텐서들을 모두 동일한 디바이스(dev)에 생성\n","    h = torch.ones((num_nodes,), device=dev, dtype=torch.float32)\n","    a = torch.ones((num_nodes,), device=dev, dtype=torch.float32)\n","\n","    # src, dst는 edge_index에서 뽑았으므로 자연스럽게 dev에 위치함\n","    src = edge_index[0]\n","    dst = edge_index[1]\n","\n","    for _ in range(iters):\n","        # Authority 업데이트\n","        a.fill_(0)\n","        a.scatter_add_(0, dst, h[src])\n","        a /= (a.max() + 1e-9)\n","\n","        # Hub 업데이트\n","        h.fill_(0)\n","        h.scatter_add_(0, src, a[dst])\n","        h /= (h.max() + 1e-9)\n","        # print(\"HITS iteration completed...\") # 출력 너무 많으면 주석 처리\n","\n","    # 3. GPU 연산이 끝났으므로 Polars와 호환되도록 CPU로 내려서 Numpy 변환\n","    return h.cpu().numpy(), a.cpu().numpy()\n","\n","# ---------------------------------------------------------\n","# 함수 교체 후 아래 코드로 실행하세요.\n","# (★중요: 누수 방지를 위해 반드시 'edge_index_train'을 변수로 넣어야 합니다!)\n","# ---------------------------------------------------------\n","hits_h, hits_a = compute_hits(edge_index, num_nodes)\n","\n","# 기존 node_feats에 병합\n","node_feats = node_feats.with_columns([\n","    pl.Series(\"g_hits_hub\", hits_h).cast(pl.Float32),\n","    pl.Series(\"g_hits_auth\", hits_a).cast(pl.Float32)\n","])\n","\n","del hits_h, hits_a\n","gc.collect()\n","print(\"✅ HITS 계산 완료!\")"],"metadata":{"id":"FgK2jgeXoQGc","executionInfo":{"status":"ok","timestamp":1773266068347,"user_tz":-540,"elapsed":628,"user":{"displayName":"DS6기_01","userId":"15970