"total_out\")).collect(engine=\"streaming\")\n","flow_stats_in = q_train_only.group_by(\"dst_id\").agg(pl.col(\"Amount_Received_USD\").sum().alias(\"total_in\")).collect(engine=\"streaming\")\n","# (이후 node_feats 조인 코드는 기존과 동일하게 유지)\n","node_feats = node_feats.join(flow_stats.rename({\"src_id\": \"node_id\"}), on=\"node_id\", how=\"left\")\n","node_feats = node_feats.join(flow_stats_in.rename({\"dst_id\": \"node_id\"}), on=\"node_id\", how=\"left\")\n","node_feats = node_feats.with_columns(\n","    (pl.col(\"total_in\").fill_null(0) / (pl.col(\"total_out\").fill_null(0) + 1e-6)).alias(\"g_flow_balance\")\n",").drop([\"total_in\", \"total_out\"])\n","\n","\n","\n","# 2. Reciprocity (상호성: A->B와 B->A가 모두 존재하는지)\n","# # 3,200만 행에서는 중복을 제거한 엣지 쌍으로 계산해야 함\n","# unique_edges = q_feat.select([\"src_id\", \"dst_id\"]).unique().collect(engine=\"streaming\")\n","# swapped_edges = unique_edges.rename({\"src_id\": \"dst_id\", \"dst_id\": \"src_id\"})\n","\n","# # 두 테이블의 교집합이 상호 거래임\n","# reciprocal_edges = unique_edges.join(swapped_edges, on=[\"src_id\", \"dst_id\"], how=\"inner\")\n","# recip_counts = reciprocal_edges.group_by(\"src_id\").count().rename({\"count\": \"g_is_reciprocal\", \"src_id\": \"node_id\"})\n","\n","# node_feats = node_feats.join(recip_counts, on=\"node_id\", how=\"left\")\n","# node_feats = node_feats.with_columns(pl.col(\"g_is_reciprocal\").fill_null(0).cast(pl.Int8))\n","\n","# del unique_edges, swapped_edges, reciprocal_edges\n","\n","# 2. Reciprocity (Train 기간의 거래만으로 상호성 검사)\n","unique_edges = q_train_only.select([\"src_id\", \"dst_id\"]).unique().collect(engine=\"streaming\")\n","# (이후 swapped_edges 등 기존 코드 동일하게 유지)\n","swapped_edges = unique_edges.rename({\"src_id\": \"dst_id\", \"dst_id\": \"src_id\"})\n","reciprocal_edges = unique_edges.join(swapped_edges, on=[\"src_id\", \"dst_id\"], how=\"inner\")\n","recip_counts = reciprocal_edges.group_by(\"src_id\").count().rename({\"count\": \"g_is_reciprocal\", \"src_id\": \"node_id\"})\n","node_feats = node_feats.join(recip_counts, on=\"node_id\", how=\"left\")\n","node_feats = node_feats.with_columns(pl.col(\"g_is_reciprocal\").fill_null(0).cast(pl.Int32))\n","del unique_edges, swapped_edges, reciprocal_edges\n","\n","gc.collect()\n","\n","###############################################################################################################################\n","# Noise 의심 피쳐 ## -> Neighbor Mule Ratio\n","###############################################################################################################################\n","\n","# # 3. Neighbor Mule Ratio (이웃 중 사기 노드 비율)\n","# # GNN의 핵심인 '전염 효과'를 명시적으로 추출\n","# print(\"Calculating Neighbor Mule Ratio...\")\n","\n","# # Train 데이터의 실제 사기꾼 ID 추출 (Leakage 방지)\n","# mule_ids = q_feat.filter((pl.col(\"split\") == \"train\") & (pl.col(\"Is Laundering\") == 1)) \\\n","#                 .select(\"src_id\").unique().collect(engine=\"streaming\")[\"src_id\"].to_numpy()\n","\n","# mule_mask = torch.zeros(num_nodes, device=device)\n","# mule_mask[mule_ids] = 1.0\n","\n","# src, dst = edge_index[0], edge_index[1]\n","# # 각 노드의 이웃들 중 mule의 수를 합산\n","# mule_neighbor_count = torch.zeros(num_nodes, device=device)\n","# mule_neighbor_count.scatter_add_(0, src, mule_mask[dst]) # 내가 보낸 대상이 mule인가?\n","# mule_neighbor_count.scatter_add_(0, dst, mule_mask[src]) # 나에게 보낸 대상이 mule인가?\n","\n","# # Ratio 계산 (Degree 활용)\n","# total_deg = (node_feats[\"g_in_degree\"] + node_feats[\"g_out_degree\"]).to_numpy()\n","# mule_ratio = mule_neighbor_count.cpu().numpy() / (total_deg + 1e-6)\n","\n","# node_feats = node_feats.with_columns(\n","#     pl.Series(\"g_mule_neighbor_ratio\", mule_ratio).cast(pl.Float32)\n","# )\n","\n","# del mule_mask, mule_neighbor_count, mule_ids\n","# gc.collect()\n","\n","# print(\"Tier 2 features completed.\")"]},{"cell_type":"markdown","metadata":{"id":"3yOdgk43eVlV"},"source":["- 3차 피처: Neighbor Mean Degree, SCC, Ego Size, Entropy\n","- 그래프의 구조적 깊이를 측정합니다."]},{"cell_type":"code","source":["print(\"Extracting 3rd Tier Features...\")\n","from scipy.sparse.csgraph import connected_components\n","from scipy.sparse import csr_matrix\n","import numpy as np\n","\n","# --- 1. SCC (Strongly Connected Components) - 이미 검증됨 ---\n","adj = csr_matrix((np.ones(edge_index.shape[1]), (edge_index[0].numpy(), edge_index[1].numpy())), shape=(num_nodes, num_nodes))\n","n_components, labels = connected_components(adj, directed=True, connection='strong')\n","\n","scc_df = pl.DataFrame({\"node_id\": np.arange(num_nodes, dtype=np.int32), \"scc_label\": labels})\n","scc_size = scc_df.group_by(\"scc_label\").count().rename({\"count\": \"g_scc_size\"})\n","scc_df = scc_df.join(scc_size, on=\"scc_label\", how=\"left\")\n","\n","node_feats = node_feats.join(scc_df.select([\"node_id\", \"g_scc_size\"]), on=\"node_id\", how=\"left\")\n","\n","del adj, scc_df, scc_size, labels\n","gc.collect()\n","\n"],"metadata":{"id":"u3ia32DuiIZA","executionInfo":{"status":"ok","timestamp":1773266070911,"user_tz":-540,"elapsed":973,"user":{"displayName":"DS6기_01","userId":"15970101082274129131"}},"colab":{"base_uri":"https://localhost:8080/"},"outputId":"afbc5a49-9ea2-4a52-fe1e-c71fbdb95369"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Extracting 3rd Tier Features...\n"]},{"output_type":"execute_result","data":{"text/plain":["0"]},"metadata":{},"execution_count":61}]},{"cell_type":"code","source":["# # --- 2. Neighbor Mean Degree (1-hop 이웃들의 평균 Degree) ---\n","# # 내 주변 계좌들이 얼마나 활발한 계좌들인지 측정 (안정적임)\n","# # print(\"Calculating Neighbor Mean Degree...\")\n","# src = edge_index[0].to(device)\n","# dst = edge_index[1].to(device)\n","# src, dst = edge_index[0], edge_index[1]\n","# # 전체 Degree (In + Out) 준비\n","# # total_deg = torch.from_numpy((node_feats[\"g_in_degree\"] + node_feats[\"g_out_degree\"]).to_numpy()).to(device)\n","# total_deg = torch.from_numpy(\n","#     (node_feats[\"g_in_degree\"] + node_feats[\"g_out_degree\"]).to_numpy()\n","# ).to(device)\n","\n","# # 이웃들의 Degree 합산 (scatter_add 사용)\n","# sum_neighbor_deg = torch.zeros(num_nodes, device=device)\n","# sum_neighbor_deg.scatter_add_(0, src, total_deg[dst]) # 내가 보낸 대상의 degree 합\n","# sum_neighbor_deg.scatter_add_(0, dst, total_deg[src]) # 나에게 보낸 대상의 degree 합\n","\n","# # 평균 계산 (전체 degree로 나눔)\n","# # current_total_deg = torch.from_numpy((node_feats[\"g_in_degree\"] + node_feats[\"g_out_degree\"]).to_numpy()).to(device)\n","# # mean_neighbor_deg = sum_neighbor_deg / (current_total_deg + 1e-6)\n","# mean_neighbor_deg = sum_neighbor_deg / (total_deg + 1e-6)\n","\n","# node_feats = node_feats.with_columns(\n","#     pl.Series(\"g_neighbor_mean_degree\", mean_neighbor_deg.cpu().numpy()).cast(pl.Float32)\n","# )\n","\n","# del src, dst, total_deg, sum_neighbor_deg, mean_neighbor_deg\n","# gc.collect()\n"],"metadata":{"id":"cCYSZ2IliKzZ"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# --- 2. Neighbor Mean Degree (1-hop 이웃들의 평균 Degree) ---\n","print(\"Calculating Neighbor Mean Degree...\")\n","\n","# 1. 현재 환경에 맞춰 디바이스를 강제로 명시합니다.\n","dev = 'cuda' if torch.cuda.is_available() else 'cpu'\n","\n","# 2. ★ 핵심: 인덱스(src, dst)를 무조건 GPU로 복사해서 올립니다!\n","src = edge_index[0].clone().detach().to(dev, dtype=torch.long)\n","dst = edge_index[1].clone().detach().to(dev, dtype=torch.long)\n","\n","# 3. 더할 값(total_deg)도 GPU로 올립니다.\n","total_deg = torch.from_numpy(\n","    (node_feats[\"g_in_degree\"] + node_feats[\"g_out_degree\"]).to_numpy()\n",").to(dev, dtype=torch.float32)\n","\n","# 4. 결과를 담을 빈 그릇도 GPU에 생성합니다.\n","sum_neighbor_deg = torch.zeros(num_nodes, device=dev, dtype=torch.float32)\n","\n","# 5. 초고속 병렬 합산 (모든 텐서가 dev에 모였으므로 절대 충돌이 나지 않습니다!)\n","sum_neighbor_deg.scatter_add_(0, src, total_deg[dst])\n","sum_neighbor_deg.scatter_add_(0, dst, total_deg[src])\n","\n","# 6. 평균 계산 후 CPU로 내려서 Polars DataFrame에 넣습니다.\n","mean_neighbor_deg = sum_neighbor_deg / (total_deg + 1e-6)\n","\n","node_feats = node_feats.with_columns(\n","    pl.Series(\"g_neighbor_mean_degree\", mean_neighbor_deg.cpu().numpy()).cast(pl.Float32)\n",")\n","\n","# 7. GPU 메모리 깔끔하게 청소\n","del src, dst, total_deg, sum_neighbor_deg, mean_neighbor_deg\n","torch.cuda.empty_cache()\n","gc.collect()\n","\n","print(\"✅ Neighbor Mean Degree 계산 완료!\")"],"metadata":{"id":"xDeG1jx4iMvm","executionInfo":{"status":"ok","timestamp":1773266071353,"user_tz":-540,"elapsed":438,"user":{"displayName":"DS6기_01","userId":"15970101082274129131"}},"colab":{"base_uri":"https://localhost:8080/"},"outputId":"c941c463-f384-46cc-f36b-c902b402fa33"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Calculating Neighbor Mean Degree...\n","✅ Neighbor Mean Degree 계산 완료!\n"]}]},{"cell_type":"code","execution_count":null,"metadata":{"executionInfo":{"elapsed":820,"status":"ok","timestamp":1773266072174,"user":{"displayName":"DS6기_01","userId":"15970101082274129131"},"user_tz":-540},"id":"4CabfpYFd7Xp","colab":{"base_uri":"https://localhost:8080/"},"outputId":"4e8ba847-543b-40f8-fa15-986000296f09"},"outputs":[{"output_type":"stream","name":"stdout","text":["Calculating Ego Network Size...\n","Tier 3 features extraction finished.\n"]}],"source":["\n","# --- 3. Ego Network Size (1-hop 유니크 이웃의 수) ---\n","# Degree와 유사하지만 '중복 거래'를 제외한 순수 연결 계좌 수\n","# 3,200만 행에서 unique() 연산은 메모리를 많이 소모하므로 주의가 필요합니다.\n","print(\"Calculating Ego Network Size...\")\n","# [위험!] 아래 코드는 3,200만 행의 중복 제거를 시도하므로 OOM 발생 시 주석처리 하세요.\n","# ego_data = q_feat.select([\"src_id\", \"dst_id\"]).unique().collect(engine=\"streaming\")\n","# ★ 누수 방지: Train 데이터 이웃만 카운트\n","ego_data = q_train_only.select([\"src_id\", \"dst_id\"]).unique().collect(engine=\"streaming\")\n","\n","ego_size_out = ego_data.group_by(\"src_id\").count().rename({\"src_id\": \"node_id\", \"count\": \"g_ego_size_out\"})\n","ego_size_in = ego_data.group_by(\"dst_id\").count().rename({\"dst_id\": \"node_id\", \"count\": \"g_ego_size_in\"})\n","\n","node_feats = node_feats.join(ego_size_out, on=\"node_id\", how=\"left\")\n","node_feats = node_feats.join(ego_size_in, on=\"node_id\", how=\"left\")\n","node_feats = node_feats.with_columns([\n","    pl.col(\"g_ego_size_out\").fill_null(0).cast(pl.Int32),\n","    pl.col(\"g_ego_size_in\").fill_null(0).cast(pl.Int32)\n","])\n","\n","del ego_data, ego_size_out, ego_size_in\n","gc.collect()\n","\n","\n","print(\"Tier 3 features extraction finished.\")"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"L3xstLs3KLMh"},"outputs":[],"source":["# import polars as pl\n","# import numpy as np\n","# import gc\n","# import os\n","\n","# # 1. 노드 마스터 사전 최적화 (메모리에 딱 1번 유지)\n","# print(\"[4-1] 노드 마스터 사전 최적화...\")\n","# # node_feats가 메모리에 있다고 가정. 타입을 최대한 압축합니다.\n","# node_master = node_feats.with_columns([\n","#     pl.col(\"node_id\").cast(pl.Int32),\n","#     *[pl.col(c).cast(pl.Float32) for c in node_feats.columns if c != \"node_id\"]\n","# ]) # 조인을 위해 마스터는 메모리에 완전히 올립니다 (약 200~300MB 수준)\n","\n","# del node_feats\n","# gc.collect()\n"]},{"cell_type":"code","source":["import polars as pl\n","import numpy as np\n","import gc\n","import os\n","\n","print(\"[4-1] 노드 마스터 사전 최적화 및 Object 타입 정제...\")\n","\n","# ============================================================\n","# ★ [추가된 핵심 로직] pl.Object 강제 정제\n","# ============================================================\n","clean_dict = {}\n","for col in node_feats.columns:\n","    series = node_feats[col]\n","\n","    # 만약 컬럼이 파이썬 객체(Object)로 뭉쳐있다면\n","    if series.dtype == pl.Object:\n","        print(f\" -> ⚠️ '{col}' 컬럼이 Object 타입입니다. 강제 숫자 변환 진행...\")\n","        # 리스트로 풀었다가 다시 numpy float32로 강제 캐스팅\n","        clean_dict[col] = np.array(series.to_list(), dtype=np.float32)\n","    else:\n","        clean_dict[col] = series\n","\n","# 깨끗해진 딕셔너리로 덮어쓰기\n","node_feats = pl.DataFrame(clean_dict)\n","\n","# ============================================================\n","# 기존 로직: 안전하게 타입 압축\n","# ============================================================\n","node_master = node_feats.with_columns([\n","    pl.col(\"node_id\").cast(pl.Int32),\n","    *[pl.col(c).cast(pl.Float32) for c in node_feats.columns if c != \"node_id\"]\n","])\n","\n","del node_feats, clean_dict\n","gc.collect()\n","\n","print(\"✅ 노드 마스터 최적화 완료! (에러 해결)\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Dy50D9GJpP6-","executionInfo":{"status":"ok","timestamp":1773266072605,"user_tz":-540,"elapsed":415,"user":{"displayName":"DS6기_01","userId":"15970101082274129131"}},"outputId":"303d1024-71dc-4230-81e0-0c5d53a87792"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["[4-1] 노드 마스터 사전 최적화 및 Object 타입 정제...\n"," -> ⚠️ 'g_pagerank' 컬럼이 Object 타입입니다. 강제 숫자 변환 진행...\n","✅ 노드 마스터 최적화 완료! (에러 해결)\n"]}]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":12239,"status":"ok","timestamp":1773266084845,"user":{"displayName":"DS6기_01","userId":"15970101082274129131"},"user_tz":-540},"id":"igYrnQXgKNIe","outputId":"78a90333-bf56-40e3-b080-6042e4eeb320"},"outputs":[{"output_type":"stream","name":"stdout","text":["🔬[Step 4-1.5] NeurIPS 2023 AML 패턴 기반 16대 모듈 피처 엔지니어링 시작...\n","⏱️ [Module 1] Velocity 피처 계산 중...\n","🔢 [Module 2] Structuring 패턴 계산 중...\n","🕸️[Module 3] Fan-out/Fan-in 피처 계산 중... (List 에러 해결)\n","🔄[Module 4 & 10] 왕복 및 Cycle 피처 계산 중...\n","💸[Module 6 & 9] Flow 및 중간 노드 피처 계산 중...\n","🎭[Module 7 & 14] Integration 위장 탐지 계산 중...\n","🌍 [Module 8 & 12] Bank-Hop & Cross-Border 피처 계산 중...\n","💱[Module 11 & 13] Payment & Crypto 피처 계산 중...\n","🔗 [Merge] 1~15 모듈 1차 마스터 병합 중...\n","🌐 [Module 5 & 16] Torch 기반 이웃 위험 전파 계산 중...\n","🏆[최종 통합] 기존 마스터와 16대 피처 최종 결합...\n","✅ 논문 기반 16대 고급 피처 엔지니어링 완벽 생성! (소요 시간: 0.20분)\n","   결합된 마스터 노드 속성 수: 29개\n"]}],"source":["import polars as pl\n","import torch\n","import numpy as np\n","import gc\n","import time\n","\n","print(\"🔬[Step 4-1.5] NeurIPS 2023 AML 패턴 기반 16대 모듈 피처 엔지니어링 시작...\")\n","start_time = time.time()\n","\n","# # ============================================================\n","# # 0. 준비 작업: 타입 일치화 (Int32) 및 Train 필터링\n","# # ============================================================\n","# q_train_only = q_feat.filter(pl.col(\"split\") == \"train\").with_columns([\n","#     pl.col(\"ts\").dt.epoch(time_unit=\"s\").alias(\"ts_epoch\"),\n","#     pl.col(\"src_id\").cast(pl.Int32),\n","#     pl.col(\"dst_id\").cast(pl.Int32)\n","# ])\n","\n","# base_df = pl.DataFrame({\"node_id\": range(num_nodes)}, schema={\"node_id\": pl.Int32})\n","\n","# ============================================================\n","# 0. 준비 작업: 타입 일치화 (Int32) 및 Train 필터링\n","# ============================================================\n","# ★ [추가된 에러 방지 코드] 현재 데이터셋 스키마 확인\n","existing_cols = q_feat.collect_schema().names()\n","fallback_exprs =[]\n","\n","# 논문 모듈 계산에 필수적인데, 현재 누락되었을 수 있는 컬럼들\n","for required_col in[\"IsCrossBorder\", \"IsToFATF\", \"IsFromFATF\", \"is_bitcoin_fmt\"]:\n","    if required_col not in existing_cols:\n","        print(f\"⚠️ 경고: '{required_col}' 컬럼이 누락되어 0(False)으로 대체합니다.\")\n","        fallback_exprs.append(pl.lit(0).alias(required_col))\n","\n","# 누락된 컬럼이 있다면 0으로 안전하게 생성 후 필터링\n","q_train_only = q_feat.filter(pl.col(\"split\") == \"train\")\n","\n","if fallback_exprs:\n","    q_train_only = q_train_only.with_columns(fallback_exprs)\n","\n","# 시간 및 타입 강제 캐스팅\n","q_train_only = q_train_only.with_columns([\n","    pl.col(\"ts\").dt.epoch(time_unit=\"s\").alias(\"ts_epoch\"),\n","    pl.col(\"src_id\").cast(pl.Int32),\n","    pl.col(\"dst_id\").cast(pl.Int32)\n","])\n","\n","# 모든 피처를 담을 베이스 프레임\n","base_df = pl.DataFrame({\"node_id\": range(num_nodes)}, schema={\"node_id\": pl.Int32})\n","\n","\n","# ============================================================\n","# MODULE 1: Velocity Features\n","# ============================================================\n","print(\"⏱️ [Module 1] Velocity 피처 계산 중...\")\n","dow_counts = q_train_only.group_by([\"src_id\", \"day_of_week\"]).len()\n","dow_totals = dow_counts.group_by(\"src_id\").agg(pl.col(\"len\").sum().alias(\"total\"))\n","dow_entropy = dow_counts.join(dow_totals, on=\"src_id\").with_columns(\n","    (pl.col(\"len\") / pl.col(\"total\")).alias(\"p\")\n",").group_by(\"src_id\").agg(\n","    (-(pl.col(\"p\") * pl.col(\"p\").log(2))).sum().cast(pl.Float32).alias(\"v_dow_entropy\")\n",")\n","\n","feat_m1 = (\n","    q_train_only.sort(\"ts_epoch\").group_by(\"src_id\").agg([\n","        pl.col(\"ts_epoch\").diff().drop_nulls().mean().alias(\"v_avg_tx_interval\"),\n","        pl.col(\"ts_epoch\").diff().drop_nulls().std().alias(\"v_std_tx_interval\"),\n","        ((pl.col(\"ts_epoch\").max() - pl.col(\"ts_epoch\").min()) / 86400).cast(pl.Float32).alias(\"v_active_span_days\"),\n","    ])\n","    .join(dow_entropy, on=\"src_id\", how=\"left\")\n","    .rename({\"src_id\": \"node_id\"})\n","    .with_columns(pl.col(\"node_id\").cast(pl.Int32))\n",")\n","del dow_counts, dow_totals, dow_entropy; gc.collect()\n","\n","\n","# ============================================================\n","# MODULE 2: Structuring Detection\n","# ============================================================\n","print(\"🔢 [Module 2] Structuring 패턴 계산 중...\")\n","STRUCTURING_THRESHOLD = 10000\n","feat_m2 = (\n","    q_train_only.group_by(\"src_id\").agg([\n","        (\n","            pl.col(\"Amount_Paid_USD\").filter((pl.col(\"Amount_Paid_USD\") >= STRUCTURING_THRESHOLD * 0.9) & (pl.col(\"Amount_Paid_USD\") < STRUCTURING_THRESHOLD)).len() /\n","            (pl.len() + 1e-6)\n","        ).cast(pl.Float32).alias(\"s_below_threshold_ratio\"),\n","        (pl.col(\"Amount_Paid_USD\").std() / (pl.col(\"Amount_Paid_USD\").mean() + 1e-6)).cast(pl.Float32).alias(\"s_amount_cv\"),\n","        (pl.col(\"Amount_Paid_USD\").is_duplicated().sum() / pl.len()).cast(pl.Float32).alias(\"s_repeated_amount_ratio\"),\n","    ]).rename({\"src_id\": \"node_id\"}).with_columns(pl.col(\"node_id\").cast(pl.Int32))\n",")\n","\n","\n","# ============================================================\n","# MODULE 3: Fan-out / Fan-in Concentration\n","# ============================================================\n","print(\"🕸️[Module 3] Fan-out/Fan-in 피처 계산 중... (List 에러 해결)\")\n","pair_sent = q_train_only.group_by([\"src_id\", \"dst_id\"]).agg(pl.col(\"Amount_Paid_USD\").sum().alias(\"pair_amt\"))\n","src_tot = pair_sent.group_by(\"src_id\").agg(pl.col(\"pair_amt\").sum().alias(\"tot\"))\n","\n","# ★ 에러 해결: agg 내부에서 List 연산을 막기 위해 with_columns로 개별 비율을 먼저 구함\n","fanout = pair_sent.join(src_tot, on=\"src_id\").with_columns([\n","    (pl.col(\"pair_amt\") / (pl.col(\"tot\") + 1e-6)).alias(\"ratio\")\n","]).group_by(\"src_id\").agg([\n","    (pl.col(\"ratio\") ** 2).sum().cast(pl.Float32).alias(\"f_sender_hhi\"),\n","    pl.col(\"ratio\").max().cast(pl.Float32).alias(\"f_top1_receiver_ratio\")\n","]).rename({\"src_id\": \"node_id\"}).with_columns(pl.col(\"node_id\").cast(pl.Int32))\n","\n","pair_recv = q_train_only.group_by([\"dst_id\", \"src_id\"]).agg(pl.col(\"Amount_Received_USD\").sum().alias(\"pair_amt\"))\n","dst_tot = pair_recv.group_by(\"dst_id\").agg(pl.col(\"pair_amt\").sum().alias(\"tot\"))\n","\n","fanin = pair_recv.join(dst_tot, on=\"dst_id\").with_columns([\n","    (pl.col(\"pair_amt\") / (pl.col(\"tot\") + 1e-6)).alias(\"ratio\")\n","]).group_by(\"dst_id\").agg([\n","    (pl.col(\"ratio\") ** 2).sum().cast(pl.Float32).alias(\"f_receiver_hhi\"),\n","]).rename({\"dst_id\": \"node_id\"}).with_columns(pl.col(\"node_id\").cast(pl.Int32))\n","\n","feat_m3 = base_df.lazy().join(fanout.lazy(), on=\"node_id\", how=\"left\").join(fanin.lazy(), on=\"node_id\", how=\"left\").collect()\n","del pair_sent, src_tot, fanout, pair_recv, dst_tot, fanin; gc.collect()\n","\n","\n","# ============================================================\n","# MODULE 4 & 10: Reciprocity & Cycle\n","# ============================================================\n","print(\"🔄[Module 4 & 10] 왕복 및 Cycle 피처 계산 중...\")\n","my_sent = q_train_only.select([\"src_id\", \"dst_id\"]).unique().rename({\"src_id\": \"node_id\", \"dst_id\": \"target\"})\n","my_recv = q_train_only.select([\"dst_id\", \"src_id\"]).unique().rename({\"dst_id\": \"node_id\", \"src_id\": \"target\"})\n","\n","overlap = my_sent.join(my_recv, on=[\"node_id\", \"target\"], how=\"inner\").group_by(\"node_id\").len().rename({\"len\": \"cy_overlap_count\"})\n","tot_sent = my_sent.group_by(\"node_id\").len().rename({\"len\": \"tot_sent_count\"})\n","\n","feat_m4_10 = overlap.join(tot_sent, on=\"node_id\", how=\"left\").with_columns([\n","    (pl.col(\"cy_overlap_count\") / (pl.col(\"tot_sent_count\") + 1e-6)).cast(pl.Float32).alias(\"cy_cycle_ratio\")\n","]).select([\"node_id\", \"cy_cycle_ratio\"]).with_columns(pl.col(\"node_id\").cast(pl.Int32))\n","del my_sent, my_recv, overlap, tot_sent; gc.collect()\n","\n","\n","# ============================================================\n","# MODULE 6 & 9: Flow Asymmetry & Scatter-Gather\n","# ============================================================\n","print(\"💸[Module 6 & 9] Flow 및 중간 노드 피처 계산 중...\")\n","recv_agg = q_train_only.group_by(\"dst_id\").agg([\n","    pl.col(\"src_id\").n_unique().alias(\"sg_in_degree\"),\n","    pl.col(\"Amount_Received_USD\").sum().alias(\"total_recv\"),\n","    pl.col(\"ts_epoch\").min().alias(\"first_recv_ts\")\n","]).rename({\"dst_id\": \"node_id\"}).with_columns(pl.col(\"node_id\").cast(pl.Int32))\n","\n","sent_agg = q_train_only.group_by(\"src_id\").agg([\n","    pl.col(\"dst_id\").n_unique().alias(\"sg_out_degree\"),\n","    pl.col(\"Amount_Paid_USD\").sum().alias(\"total_sent\"),\n","    pl.col(\"ts_epoch\").min().alias(\"first_sent_ts\")\n","]).rename({\"src_id\": \"node_id\"}).with_columns(pl.col(\"node_id\").cast(pl.Int32))\n","\n","feat_m6_9 = (\n","    base_df.lazy()\n","    .join(recv_agg.lazy(), on=\"node_id\", how=\"left\")\n","    .join(sent_agg.lazy(), on=\"node_id\", how=\"left\")\n","    .with_columns(pl.all().exclude(\"node_id\").fill_null(0.0))\n","    .with_columns([\n","        (pl.min_horizontal(\"total_sent\", \"total_recv\") / (pl.max_horizontal(\"total_sent\", \"total_recv\") + 1e-6)).cast(pl.Float32).alias(\"fa_passthrough_ratio\"),\n","        (pl.min_horizontal(\"sg_in_degree\", \"sg_out_degree\") / (pl.max_horizontal(\"sg_in_degree\", \"sg_out_degree\") + 1e-6)).cast(pl.Float32).alias(\"sg_balance\"),\n","        (pl.col(\"first_sent_ts\") - pl.col(\"first_recv_ts\")).clip(lower_bound=0).cast(pl.Float32).alias(\"sg_delay_sec\")\n","    ]).select([\"node_id\", \"fa_passthrough_ratio\", \"sg_balance\", \"sg_delay_sec\"])\n","    .collect()\n",")\n","del recv_agg, sent_agg; gc.collect()\n","\n","\n","# ============================================================\n","# MODULE 7 & 14: Temporal Regularity & Integration\n","# ============================================================\n","print(\"🎭[Module 7 & 14] Integration 위장 탐지 계산 중...\")\n","feat_m7_14 = (\n","    q_train_only.group_by(\"src_id\").agg([\n","        (\n","            pl.col(\"Amount_Paid_USD\").filter((pl.col(\"is_dawn\") == 1) | (pl.col(\"is_weekend\") == 1)).sum() /\n","            (pl.col(\"Amount_Paid_USD\").sum() + 1e-6)\n","        ).cast(pl.Float32).alias(\"it_offhour_amt_ratio\"),\n","        pl.col(\"hour_sin\").std().cast(pl.Float32).alias(\"tr_hour_std\")\n","    ]).rename({\"src_id\": \"node_id\"}).with_columns(pl.col(\"node_id\").cast(pl.Int32))\n",")\n","\n","\n","# ============================================================\n","# MODULE 8 & 12: Cross-Border & Bank-Hop\n","# ============================================================\n","print(\"🌍 [Module 8 & 12] Bank-Hop & Cross-Border 피처 계산 중...\")\n","feat_m8_12 = (\n","    q_train_only.group_by(\"src_id\").agg([\n","        pl.col(\"To Bank\").n_unique().cast(pl.Float32).alias(\"bh_unique_dest_banks\"),\n","        ((pl.col(\"From Bank\") != pl.col(\"To Bank\")).sum() / pl.len()).cast(pl.Float32).alias(\"bh_cross_bank_ratio\"),\n","        pl.col(\"IsCrossBorder\").mean().cast(pl.Float32).alias(\"cb_crossborder_ratio\"),\n","        pl.col(\"IsToFATF\").mean().cast(pl.Float32).alias(\"cb_fatf_ratio\"),\n","    ]).rename({\"src_id\": \"node_id\"}).with_columns(pl.col(\"node_id\").cast(pl.Int32))\n",")\n","\n","\n","# ============================================================\n","# MODULE 11 & 13: Currency Switching & Payment Type\n","# ============================================================\n","print(\"💱[Module 11 & 13] Payment & Crypto 피처 계산 중...\")\n","feat_m11_13 = (\n","    q_train_only.group_by(\"src_id\").agg([\n","        pl.col(\"is_bitcoin_fmt\").mean().cast(pl.Float32).alias(\"pt_crypto_ratio\"),\n","        pl.col(\"risk_x_log_paid\").mean().cast(pl.Float32).alias(\"pt_avg_risk_amt\"),\n","    ]).rename({\"src_id\": \"node_id\"}).with_columns(pl.col(\"node_id\").cast(pl.Int32))\n",")\n","\n","\n","# ============================================================\n","# 모든 1~15 모듈 1차 마스터 병합\n","# ============================================================\n","print(\"🔗 [Merge] 1~15 모듈 1차 마스터 병합 중...\")\n","advanced_features = (\n","    base_df.lazy()\n","    .join(feat_m1.lazy(), on=\"node_id\", how=\"left\")\n","    .join(feat_m2.lazy(), on=\"node_id\", how=\"left\")\n","    .join(feat_m3.lazy(), on=\"node_id\", how=\"left\")\n","    .join(feat_m4_10.lazy(), on=\"node_id\", how=\"left\")\n","    .join(feat_m6_9.lazy(), on=\"node_id\", how=\"left\")\n","    .join(feat_m7_14.lazy(), on=\"node_id\", how=\"left\")\n","    .join(feat_m8_12.lazy(), on=\"node_id\", how=\"left\")\n","    .join(feat_m11_13.lazy(), on=\"node_id\", how=\"left\")\n","    .with_columns(pl.all().exclude(\"node_id\").fill_null(0.0))\n","    .collect()\n",")\n","del feat_m1, feat_m2, feat_m3, feat_m4_10, feat_m6_9, feat_m7_14, feat_m8_12, feat_m11_13; gc.collect()\n","\n","\n","# ============================================================\n","# MODULE 5 & 16: 이웃 위험도 전파 (Torch)\n","# ============================================================\n","print(\"🌐 [Module 5 & 16] Torch 기반 이웃 위험 전파 계산 중...\")\n","\n","_edges = q_train_only.select([\"src_id\", \"dst_id\"]).collect()\n","edge_index_train = torch.tensor(\n","    np.stack([_edges[\"src_id\"].to_numpy(), _edges[\"dst_id\"].to_numpy()]),\n","    dtype=torch.long\n",")\n","del _edges; gc.collect()\n","\n","risk_tensor = torch.tensor(\n","    advanced_features.sort(\"node_id\")[\"fa_passthrough_ratio\"].to_numpy(),\n","    dtype=torch.float32, device='cuda' if torch.cuda.is_available() else 'cpu'\n",")\n","\n","src_t = edge_index_train[0].to(risk_tensor.device)\n","dst_t = edge_index_train[1].to(risk_tensor.device)\n","\n","sum_neighbor_risk = torch.zeros(num_nodes, dtype=torch.float32, device=risk_tensor.device).scatter_add_(0, src_t, risk_tensor[dst_t])\n","count_sent = torch.zeros(num_nodes, dtype=torch.float32, device=risk_tensor.device).scatter_add_(0, src_t, torch.ones_like(src_t, dtype=torch.float32))\n","\n","mean_neighbor_risk = (sum_neighbor_risk / count_sent.clamp(min=1)).cpu().numpy()\n","\n","feat_m16 = pl.DataFrame({\n","    \"node_id\": np.arange(num_nodes, dtype=np.int32),\n","    \"nr_mean_neighbor_risk\": mean_neighbor_risk.astype(np.float32)\n","})\n","del risk_tensor, src_t, dst_t, sum_neighbor_risk, count_sent, mean_neighbor_risk, edge_index_train; gc.collect()\n","\n","\n","# ============================================================\n","# 최종 통합 마스터 (최적화 완료본)\n","# ============================================================\n","print(\"🏆[최종 통합] 기존 마스터와 16대 피처 최종 결합...\")\n","\n","DROP_OLD =[\"g_hits_hub\", \"g_hits_auth\", \"g_degree_ratio\", \"g_flow_balance\", \"g_scc_size\", \"g_neighbor_mean_degree\"]\n","node_master_slim = node_master.drop([c for c in DROP_OLD if c in node_master.columns])\n","\n","full_node_master = (\n","    node_master_slim.lazy()\n","    .join(advanced_features.lazy(), on=\"node_id\", how=\"left\")\n","    .join(feat_m16.lazy(), on=\"node_id\", how=\"left\")\n","    .with_columns(pl.all().exclude(\"node_id\").fill_null(0.0))\n","    .collect()\n",")\n","\n","del node_master, node_master_slim, advanced_features, feat_m16; gc.collect()\n","\n","end_time = time.time()\n","print(f\"✅ 논문 기반 16대 고급 피처 엔지니어링 완벽 생성! (소요 시간: {(end_time - start_time)/60:.2f}분)\")\n","print(f\"   결합된 마스터 노드 속성 수: {len(full_node_master.columns)-1}개\")"]},{"cell_type":"code","execution_count":null,"metadata":{"executionInfo":{"elapsed":10,"status":"ok","timestamp":1773266084856,"user":{"displayName":"DS6기_01","userId":"15970101082274129131"},"user_tz":-540},"id":"yilQjtOA9Y9a","colab":{"base_uri":"https://localhost:8080/"},"outputId":"5ac23fc6-677d-4a01-93a5-a73edef5b10a"},"outputs":[{"output_type":"stream","name":"stdout","text":["[4-2] 거래 데이터 슬림화...\n"]}],"source":["\n","# 2. 거래 데이터(q_feat) 슬림화\n","print(\"[4-2] 거래 데이터 슬림화...\")\n","# KEEP_RAW_COLS = [\n","#     \"src_id\", \"dst_id\",\"Is Laundering\", \"split\", \"Amount_Paid_USD\",\"Amount_Received_USD\",\n","#     \"hour_sin\", \"hour_cos\", \"day_of_week\", \"is_weekend\",\"ts_day\", \"is_dawn\",\n","#     \"log_amount_paid_usd\", \"log_amount_received_usd\", \"is_round_1000_paid\",\n","#     \"From Bank\", \"To Bank\", \"IsCrossBorder\", \"IsFromFATF\", \"IsToFATF\",\n","#     \"From Country\", \"To Country\", \"Sender_Bank_Branch_ID\", \"Receive_Bank_Branch_ID\",\n","#     \"Is_Intra_Bank\", \"bucket_ts_str\",\"is_bitcoin_fmt\", \"risk_x_log_paid\"\n","# ]\n","\n","# Lazy 상태 유지\n","# q_slim = q_feat.select([c for c in KEEP_RAW_COLS if c in q_feat.collect_schema().names()])\n","q_slim = q_feat.select(\"*\")\n","\n","# 3. 배치 조인 시작 (sink_parquet 도입)\n","total_rows = 32000000\n","batch_size = 1000000\n","output_dir = \"/content/final_chunks\"\n","os.makedirs(output_dir, exist_ok=True)\n","\n","graph_cols = [c for c in full_node_master.columns if c != \"node_id\"]"]},{"cell_type":"code","source":["import polars as pl\n","\n","print(\"🕵️‍♂️[데이터 진단] 누락 컬럼 및 깡통(All-Zero) 피처 추적 시작...\\n\")\n","\n","# ============================================================\n","# 1. 원본 데이터(q_feat) 누락 컬럼 추적\n","# ============================================================\n","# 논문 모듈들이 참조하기로 기대했던 핵심 원본 컬럼 리스트\n","expected_raw_cols =[\n","    \"Amount_Paid_USD\", \"Amount_Received_USD\", \"is_dawn\", \"is_weekend\",\n","    \"day_of_week\", \"hour_sin\", \"To Bank\", \"From Bank\",\n","    \"IsCrossBorder\", \"IsToFATF\", \"IsFromFATF\", \"is_bitcoin_fmt\"\n","]\n","\n","existing_raw_cols = q_feat.collect_schema().names()\n","missing_raw_cols = [col for col in expected_raw_cols if col not in existing_raw_cols]\n","\n","print(\"-\" * 60)\n","print(f\"🚨 1. 원본 데이터 누락 확인 (총 {len(missing_raw_cols)}개 누락)\")\n","print(\"-\" * 60)\n","if missing_raw_cols:\n","    for col in missing_raw_cols:\n","        print(f\"  ❌ 누락됨: '{col}' (-> 강제로 0 처리됨)\")\n","else:\n","    print(\"  ✅ 기대했던 모든 원본 컬럼이 정상적으로 존재합니다.\")\n","\n","\n","# ============================================================\n","# 2. 최종 마스터(full_node_master)의 '깡통(All-Zero)' 피처 추적\n","# ============================================================\n","# full_node_master가 메모리에 DataFrame으로 존재한다고 가정합니다.\n","# 모든 값이 0.0 인 피처를 찾아냅니다. (절대값의 합이 0이면 전부 0인 것)\n","\n","# 숫자형 컬럼만 추출 (node_id 제외)\n","numeric_cols =[\n","    col for col, dtype in full_node_master.schema.items()\n","    if dtype in pl.NUMERIC_DTYPES and col != \"node_id\"\n","]\n","\n","# 한 번의 쿼리로 모든 컬럼의 (최대값 == 0 & 최소값 == 0) 여부를 검사\n","zero_check_exprs =[\n","    ((pl.col(c).max() == 0.0) & (pl.col(c).min() == 0.0)).alias(c)\n","    for c in numeric_cols\n","]\n","\n","# 검사 실행 (1줄의 결과로 나옴)\n","zero_check_result = full_node_master.select(zero_check_exprs).to_dicts()[0]\n","\n","# 결과가 True(전부 0)인 피처만 필터링\n","all_zero_features =[feat for feat, is_zero in zero_check_result.items() if is_zero]\n","\n","print(\"\\n\" + \"-\" * 60)\n","print(f\"🗑️ 2. 전부 0으로 채워진 '깡통 피처' 확인 (총 {len(all_zero_features)}개)\")\n","print(\"-\" * 60)\n","if all_zero_features:\n","    print(\"  이 피처들은 값이 모두 0이므로 XGBoost 학습에 아무런 도움을 주지 못합니다.\")\n","    print(\"  (조인 속도 향상을 위해 Drop 하는 것을 권장합니다.)\\n\")\n","    for feat in all_zero_features:\n","        print(f\"  - {feat}\")\n","else:\n","    print(\"  ✅ 전부 0으로만 채워진 깡통 피처가 없습니다. (모든 피처가 활성화됨)\")\n","\n","print(\"\\n진단 완료.\")"],"metadata":{"id":"lPfgU3-yt4E7","executionInfo":{"status":"ok","timestamp":1773266084894,"user_tz":-540,"elapsed":21,"user":{"displayName":"DS6기_01","userId":"15970101082274129131"}},"colab":{"base_uri":"https://localhost:8080/"},"outputId":"e0ff5375-778f-42fc-a7a0-952e86d675de"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["🕵️‍♂️[데이터 진단] 누락 컬럼 및 깡통(All-Zero) 피처 추적 시작...\n","\n","------------------------------------------------------------\n","🚨 1. 원본 데이터 누락 확인 (총 0개 누락)\n","------------------------------------------------------------\n","  ✅ 기대했던 모든 원본 컬럼이 정상적으로 존재합니다.\n","\n","------------------------------------------------------------\n","🗑️ 2. 전부 0으로 채워진 '깡통 피처' 확인 (총 0개)\n","------------------------------------------------------------\n","  ✅ 전부 0으로만 채워진 깡통 피처가 없습니다. (모든 피처가 활성화됨)\n","\n","진단 완료.\n"]}]},{"cell_type":"code","execution_count":null,"metadata":{"id":"UOT_qN6Tv_m7","colab":{"base_uri":"https://localhost:8080/"},"outputId":"52cd3d5b-ef43-40b5-9d72-e2002c52040a","executionInfo":{"status":"ok","timestamp":1773266233172,"user_tz":-540,"elapsed":148278,"user":{"displayName":"DS6기_01","userId":"15970101082274129131"}}},"outputs":[{"output_type":"stream","name":"stdout","text":["[4-3] Polars Native 스트리밍 조인 및 병렬 저장 시작...\n","✅ 모든 데이터 변환 및 저장이 완료되었습니다! (소요 시간: 2.47분)\n","✅ 저장 위치: /content/final_full_dataset.parquet\n"]},{"output_type":"execute_result","data":{"text/plain":["0"]},"metadata":{},"execution_count":70}],"source":["import polars as pl\n","import gc\n","import time\n","\n","print(\"[4-3] Polars Native 스트리밍 조인 및 병렬 저장 시작...\")\n","start_time = time.time()\n","\n","# -------------------------------------------------------------------------\n","# ★ [핵심 1] Python for문을 사용하지 않습니다!\n","# 3,200만 행 전체 LazyFrame(q_slim)에 대해 조인 '계획(Plan)'만 한 번에 세웁니다.\n","# -------------------------------------------------------------------------\n","# graph_cols = [c for c in node_master.columns if c != \"node_id\"]\n","\n","# Left Join 플랜 작성\n","# 주의: 스트리밍 엔진에서 Left Join을 효율적으로 하려면 우측 테이블(node_master)은\n","# 메모리에 올려진 DataFrame 상태를 그대로 쓰는 것이 좋습니다. (.lazy() 생략)\n","q_joined = q_slim.with_columns([\n","    pl.col(\"src_id\").cast(pl.Int32),\n","    pl.col(\"dst_id\").cast(pl.Int32)\n","]).join(\n","    full_node_master.lazy().rename({c: f\"s_{c}\" for c in graph_cols}),\n","    left_on=\"src_id\", right_on=\"node_id\", how=\"left\"\n",").join(\n","    full_node_master.lazy().rename({c: f\"r_{c}\" for c in graph_cols}),\n","    left_on=\"dst_id\", right_on=\"node_id\", how=\"left\"\n",")\n","\n","# 결측치 채우기 및 GNN용 식별자(src_id, dst_id) 유지!\n","# Lazy 상태이므로 collect_schema()로 컬럼명을 가져옵니다.\n","g_cols =[c for c in q_joined.collect_schema().names() if c.startswith(\"s_g_\") or c.startswith(\"r_g_\")]\n","q_joined = q_joined.with_columns([\n","    pl.col(c).cast(pl.Float32).fill_null(0.0) for c in g_cols\n","])\n","\n","# -------------------------------------------------------------------------\n","# ★ [핵심 2] 한 번의 sink_parquet 호출로 모든 병렬/스트리밍 처리를 Polars에 위임\n","# -------------------------------------------------------------------------\n","output_path = \"/content/final_full_dataset.parquet\"\n","\n","# 내부적으로 CPU 코어를 100% 가동하며, OOM이 나지 않을 단위로 알아서 쪼개어 파일로 씁니다.\n","q_joined.sink_parquet(\n","    output_path,\n","    compression=\"snappy\",\n","    row_group_size=1000000 # 100만 행 단위로 row_group을 나누어 저장\n",")\n","\n","end_time = time.time()\n","print(f\"✅ 모든 데이터 변환 및 저장이 완료되었습니다! (소요 시간: {(end_time - start_time)/60:.2f}분)\")\n","print(f\"✅ 저장 위치: {output_path}\")\n","\n","# 메모리 정리\n","del full_node_master, q_joined\n","gc.collect()\n","\n"]},{"cell_type":"code","source":["# q_model = pl.scan_parquet(\"/content/final_full_dataset.parquet\")"],"metadata":{"id":"LxbyI2jEXIfD"},"execution_count":null,"outputs